{
  "expo": {
    "name": "Prepora - AI Meal Planner",
    "slug": "prepora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prepora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Prepora is your AI-powered meal planner and recipe organizer. Generate personalized daily or weekly meal plans based on ingredients in your pantry. Features smart grocery tracking, healthy eating suggestions, comfort food recipes, and a favorites cookbook. Perfect for meal prep, reducing food waste, and simplifying your cooking routine. Plan smart. Eat better. Live easier.",
    "primaryColor": "#FF9B85",
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#FEFEFE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prepora.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of ingredients",
        "NSPhotoLibraryUsageDescription": "Access photos from your gallery"
      }
    },
    "android": {
      "package": "co.median.android.odmaeyb",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF9B85"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FEFEFE"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "prepora-meal-planner"
      }
    }
  }
}
